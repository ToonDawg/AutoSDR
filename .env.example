# ---------------------------------------------------------------------------
# AutoSDR POC — environment configuration
# Copy to .env and fill in values. Do not commit .env.
# ---------------------------------------------------------------------------

# ----- LLM (Gemini by default) ---------------------------------------------
# Get a key from https://aistudio.google.com/app/apikey (free tier works for POC).
GEMINI_API_KEY=

# Model slots. Split between main and lite models to stretch free-tier quotas.
LLM_MODEL_MAIN=gemini/gemini-3-flash-preview
LLM_MODEL_ANALYSIS=gemini/gemini-3-flash-preview
LLM_MODEL_EVAL=gemini/gemini-3.1-flash-lite-preview
LLM_MODEL_CLASSIFICATION=gemini/gemini-3.1-flash-lite-preview

LLM_TEMPERATURE_MAIN=0.7
LLM_TEMPERATURE_EVAL=0.0

# ----- Connector -----------------------------------------------------------
# `file`    — writes outgoing messages to data/outbox.jsonl; accepts simulated
#             replies via POST /api/webhooks/sim. Use for dev/testing without
#             a phone. Same as passing --dry-run to `autosdr run`.
# `textbee` — hosted Android SMS gateway via textbee.dev. Poll-based: no
#             public URL or ngrok. Requires TEXTBEE_API_KEY + TEXTBEE_DEVICE_ID.
# `smsgate` — self-hosted Android SMS gateway (capcom6/android-sms-gateway).
#             Run `docker run -p 3000:3000 ghcr.io/android-sms-gateway/server:latest`
#             on your machine and install the APK on your phone. Webhook-based
#             — the phone POSTs to our /api/webhooks/sms endpoint on the LAN.
CONNECTOR=file

# TextBee config (only used when CONNECTOR=textbee)
TEXTBEE_API_URL=https://api.textbee.dev
TEXTBEE_API_KEY=
TEXTBEE_DEVICE_ID=
# Messages fetched per poll (1-100). 50 is plenty for any sane outbound rate.
TEXTBEE_POLL_LIMIT=50

# SmsGate config (only used when CONNECTOR=smsgate). API URL must include the
# full /3rdparty/v1 path segment. Examples:
#   Local docker: http://localhost:3000/api/3rdparty/v1
#   On-device:    http://192.168.1.50:8080/3rdparty/v1
SMSGATE_API_URL=http://localhost:3000/api/3rdparty/v1
SMSGATE_USERNAME=
SMSGATE_PASSWORD=

# ----- Test modes ---------------------------------------------------------
# DRY_RUN=true forces CONNECTOR=file regardless of what you set above — great
# for running the full pipeline against the real LLM without texting anyone.
# Equivalent to passing `--dry-run` to `autosdr run`.
# DRY_RUN=false
#
# SMS_OVERRIDE_TO=+61400000000 redirects every outbound SMS to this number,
# no matter which lead it was originally for. Use to rehearse real sends
# against your own phone before pointing the agent at live leads. Inbound
# from the override number is remapped back to the last real target so the
# reply pipeline routes correctly. Equivalent to passing `--override-to`.
# SMS_OVERRIDE_TO=

# ----- Server --------------------------------------------------------------
# FastAPI hosts /healthz, /api/webhooks/sms (push connectors), and
# /api/webhooks/sim (dev simulator). Poll-based connectors (TextBee) ignore
# /api/webhooks/sms; the scheduler polls them directly.
HOST=127.0.0.1
PORT=8000

# ----- Database ------------------------------------------------------------
# SQLite file path. Leave default for POC.
DATABASE_URL=sqlite:///data/autosdr.db

# ----- Kill switch ---------------------------------------------------------
PAUSE_FLAG_PATH=data/.autosdr-pause
PID_FILE_PATH=data/autosdr.pid

# ----- Logging / observability ---------------------------------------------
# LLM_LOG_ENABLED=true writes every LLM call to the llm_call table AND to
# data/logs/llm-YYYYMMDD.jsonl. Turn off only if storage is tight.
LOG_DIR=data/logs
LLM_LOG_ENABLED=true
# Prompts longer than this are truncated in the persistent log (tokens_in is
# still the true count). 0 = no truncation.
LLM_LOG_MAX_PROMPT_CHARS=16000

# ----- Scheduler (all override workspace.settings at runtime if set) -------
# SCHEDULER_TICK_S=60
# MIN_INTER_SEND_DELAY_S=30
# MAX_BATCH_PER_TICK=2
# INBOUND_POLL_S=20
